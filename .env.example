# ─────────────────────────────────────────────────────────────────────────────
# TrialVault — Environment Variables
# Copy this file to frontend/.env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Midnight Network ─────────────────────────────────────────────────────────
# Public RPC endpoint for Midnight testnet.
# No account needed — this is a public endpoint.
NEXT_PUBLIC_MIDNIGHT_RPC_URL=https://rpc.testnet.midnight.network

# Midnight indexer (used to query on-chain state like trial list, event counts).
NEXT_PUBLIC_MIDNIGHT_INDEXER_URL=https://indexer.testnet.midnight.network

# ─── WalletConnect (optional for demo, required for mobile) ───────────────────
# Get a free projectId at: https://cloud.walletconnect.com
# Steps: Sign up → New Project → copy "Project ID"
# Leave blank to run in injected-wallet-only mode (Lace / MetaMask in browser).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=trialvault

# ─── Contract Addresses (populated after running: npm run deploy) ─────────────
# Run `cd frontend && npm run compile` then `npm run deploy` to deploy to testnet.
# The deploy script writes to contracts/deploy/addresses.json — copy values here.
NEXT_PUBLIC_REGISTRY_CONTRACT_ADDRESS=
NEXT_PUBLIC_PATIENT_VAULT_CONTRACT_ADDRESS=
NEXT_PUBLIC_TRIAL_MATCHER_CONTRACT_ADDRESS=
NEXT_PUBLIC_LICENSE_MARKET_CONTRACT_ADDRESS=
NEXT_PUBLIC_RESULT_INTEGRITY_CONTRACT_ADDRESS=
NEXT_PUBLIC_EVENT_REPORTER_CONTRACT_ADDRESS=
NEXT_PUBLIC_TVAULT_TOKEN_ADDRESS=

# ─── Pinata IPFS (optional — only needed for encrypted vault backup) ──────────
# Get free API keys at: https://app.pinata.cloud
# Steps: Sign up → API Keys → New Key → enable pinFileToIPFS → copy key + secret
PINATA_API_KEY=2a84795dcd568c2369a1
PINATA_SECRET_KEY=ba7c23c0fa7031487e54fec686a121ecb49882759d12a69aca3d3b6e1fcb0651
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# ─── Contract Deployment (only needed when running: npm run deploy) ───────────
# 24-word BIP-39 mnemonic for the Midnight testnet deployer wallet.
# Get testnet DUST tokens from: https://midnight.network/testnet-faucet
# WARNING: never use a mainnet wallet here.
MIDNIGHT_DEPLOYER_MNEMONIC=
